{
  "name": "soothsayer",
  "productName": "Soothsayer",
  "version": "0.16.0",
  "private": true,
  "description": "Path of Exile divination card tracker",
  "license": "AGPL-3.0-or-later",
  "main": ".vite/build/main.js",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/navali-creations/soothsayer.git"
  },
  "scripts": {
    "dev": "pnpm supabase:start && pnpm start",
    "start": "electron-forge start",
    "package": "electron-forge package",
    "make": "electron-forge make",
    "publish": "electron-forge publish",
    "typecheck": "tsc --noEmit",
    "check": "biome check .",
    "check:fix": "biome check --write .",
    "migration:create": "node main/modules/database/migrations/create-migration.ts",
    "prepare-deps:electron": "electron-rebuild -f -w better-sqlite3",
    "postinstall": "pnpm prepare-deps:electron",
    "supabase:start": "bash scripts/setup-local-dev.sh",
    "supabase:start:fresh": "bash scripts/setup-local-dev-fresh.sh",
    "supabase:stop": "bash scripts/stop-local-dev.sh",
    "supabase:sync": "bash scripts/sync-data.sh",
    "supabase:logs": "pnpx supabase functions serve --inspect-mode=run",
    "supabase:functions:serve": "pnpx supabase functions serve",
    "vitest": "node scripts/vitest-electron.mjs",
    "test": "pnpm vitest run --config vitest.main.config.mts && vitest run --config vitest.renderer.config.mts",
    "test:main": "pnpm vitest run --config vitest.main.config.mts",
    "test:main:coverage": "pnpm vitest run --config vitest.main.config.mts --coverage",
    "test:renderer": "vitest run --config vitest.renderer.config.mts",
    "test:renderer:coverage": "vitest run --config vitest.renderer.config.mts --coverage",
    "test:e2e": "pnpm prepare-deps:electron && pnpm test:e2e:run",
    "test:e2e:run": "cross-env E2E_TESTING=true playwright test --config playwright.config.ts",
    "test:supabase:db": "bash scripts/test-db.sh",
    "test:supabase:edge": "bash scripts/test-edge.sh",
    "test:all": "pnpm vitest run --config vitest.main.config.mts && vitest run --config vitest.renderer.config.mts && bash scripts/test-db.sh && bash scripts/test-edge.sh && pnpm test:e2e"
  },
  "engines": {
    "node": ">=24",
    "pnpm": ">=10"
  },
  "packageManager": "pnpm@10.28.0",
  "keywords": [],
  "author": {
    "name": "Sebastian Krzyżanowski",
    "email": "eskrzy@gmail.com"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.12",
    "@changesets/changelog-github": "^0.6.0",
    "@changesets/cli": "^2.31.0",
    "@electron-forge/cli": "^7.10.2",
    "@electron-forge/maker-deb": "^7.10.2",
    "@electron-forge/maker-rpm": "^7.10.2",
    "@electron-forge/maker-squirrel": "^7.10.2",
    "@electron-forge/maker-zip": "^7.10.2",
    "@electron-forge/plugin-auto-unpack-natives": "^7.10.2",
    "@electron-forge/plugin-fuses": "^7.10.2",
    "@electron-forge/plugin-vite": "^7.10.2",
    "@electron-forge/publisher-github": "^7.10.2",
    "@electron/fuses": "^2.1.1",
    "@electron/rebuild": "^4.0.4",
    "@playwright/test": "^1.59.1",
    "@redux-devtools/extension": "^4.0.0",
    "@repere/react": "^0.3.3",
    "@sentry/electron": "^7.12.0",
    "@sentry/vite-plugin": "^5.2.0",
    "@supabase/supabase-js": "^2.105.0",
    "@tailwindcss/vite": "^4.2.4",
    "@tanstack/react-router": "^1.168.23",
    "@tanstack/react-router-devtools": "^1.166.13",
    "@tanstack/react-table": "^8.21.3",
    "@tanstack/router-plugin": "^1.167.22",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/better-sqlite3": "^7.6.13",
    "@types/electron-squirrel-startup": "^1.0.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "@vitest/coverage-v8": "^4.0.18",
    "@vitest/ui": "^4.0.18",
    "clsx": "^2.1.1",
    "cross-env": "^10.1.0",
    "daisyui": "^5.5.19",
    "dompurify": "^3.4.0",
    "electron": "41.3.0",
    "electron-devtools-installer": "^4.0.0",
    "electron-squirrel-startup": "^1.0.1",
    "electron-store": "^11.0.2",
    "immer": "^11.1.4",
    "jsdom": "^29.0.2",
    "kysely": "^0.28.16",
    "motion": "^12.38.0",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "react-icons": "^5.6.0",
    "react-markdown": "^10.1.0",
    "recharts": "^3.8.1",
    "rehype-raw": "^7.0.0",
    "remark-gfm": "^4.0.1",
    "supabase": "^2.95.5",
    "tailwind-merge": "^3.5.0",
    "tailwindcss": "^4.2.4",
    "typescript": "^6.0.3",
    "vite": "^8.0.9",
    "vite-plugin-externalize-deps": "^0.10.0",
    "vitest": "^4.0.18",
    "zustand": "^5.0.12"
  },
  "dependencies": {
    "@navali/poe1-divination-cards": "^3.28.2",
    "better-sqlite3": "^12.9.0",
    "tslib": "^2.8.1"
  }
}
