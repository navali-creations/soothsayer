{
  "compilerOptions": {
    "jsx": "react-jsx",
    "target": "ES2024",
    "lib": ["ES2024", "DOM"],
    "module": "ESNext",
    "allowJs": true,
    "skipLibCheck": true,
    "strict": true,
    "noImplicitAny": true,
    "sourceMap": true,
    "outDir": "dist",
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "types": ["node"],
    "paths": {
      "~/renderer/assets/*": ["./renderer/assets/*"],
      "~/renderer/components/*": ["./renderer/components/*"],
      "~/renderer/hooks/*": ["./renderer/hooks/*"],
      "~/renderer/modules/*": ["./renderer/modules/*"],
      "~/renderer/routes/*": ["./renderer/routes/*"],
      "~/renderer/store": ["./renderer/store/index.ts"],
      "~/renderer/*": ["./renderer/*"],
      "~/main/*": ["./main/*"],
      "~/types/*": ["./types/*"],
      "~/enums/*": ["./enums/*"]
    }
  },
  "include": [
    "renderer/**/*",
    "main/**/*",
    "types/**/*",
    "enums/**/*",
    "forge.env.d.ts",
    "vite-env.d.ts"
  ],
  "exclude": [
    "vite.config.ts",
    "vite.*.config.mts",
    "*.config.ts",
    "*.config.mts",
    "renderer/**/*.test.ts",
    "renderer/**/*.test.tsx",
    "renderer/**/__test-setup__/**",
    "main/**/__tests__/**",
    "main/**/__test-setup__/**"
  ]
}
